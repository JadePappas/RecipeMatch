<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F8F8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, User!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Let's find something to cook!"
                android:textSize="16sp"
                android:textColor="#666666"
                android:layout_marginBottom="24dp"/>

            <!-- Pantry Check Green Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E8F5E9"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pantry Check"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#2E7D32" />

                    <TextView
                        android:id="@+id/tv_items_available"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calculating items..."
                        android:layout_marginTop="8dp"
                        android:textColor="#2E7D32" />

                    <TextView
                        android:id="@+id/tv_recipes_found"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Finding recipes you can make..."
                        android:textColor="#2E7D32"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btn_update_pantry"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update Pantry →"
                        android:textColor="#2E7D32"
                        android:layout_gravity="end"
                        android:padding="0dp"
                        android:textAllCaps="false"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recommended Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Recommended For You"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/see_all_recommended"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="see all"
                    android:textColor="#2196F3" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recommended"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:orientation="horizontal" />

            <!-- Explore Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleLine="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_breakfast"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Breakfast"
                        style="@style/Widget.MaterialComponents.Chip.Action" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_lunch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lunch"
                        style="@style/Widget.MaterialComponents.Chip.Action" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_dinner"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dinner"
                        style="@style/Widget.MaterialComponents.Chip.Action" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_healthy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Healthy"
                        style="@style/Widget.MaterialComponents.Chip.Action" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_dessert"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dessert"
                        style="@style/Widget.MaterialComponents.Chip.Action" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_sweet"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sweet"
                        style="@style/Widget.MaterialComponents.Chip.Action" />

                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- Overlay container for recipe details -->
    <FrameLayout
        android:id="@+id/home_recipe_detail_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:elevation="8dp"
        android:visibility="gone" />

</FrameLayout>